---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 | LMF" description="Page not found">
  <section class="hero compact">
    <div class="hero-copy">
      <p class="eyebrow">404</p>
      <h1>That page drifted off.</h1>
      <p class="lede">
        The rebuilt blog is still small enough that getting back on track should be easy.
      </p>
      <div class="hero-actions">
        <a class="button-primary" href="/">Home</a>
        <a class="button-secondary" href="/links">Friend Links</a>
      </div>
    </div>
    <div class="hero-stack" aria-hidden="true">
      <img src="/images/legacy/bei.PNG" alt="" />
      <img src="/images/legacy/december.PNG" alt="" />
    </div>
  </section>
</BaseLayout>
