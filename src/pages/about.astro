---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | LMF" description="About LMF">
  <section class="hero compact">
    <div class="hero-copy">
      <p class="eyebrow">About</p>
      <h1>LMF</h1>
      <p class="lede">
        A quieter blog that keeps room for denser writing later: notes, long posts,
        and the occasional side project.
      </p>
    </div>
    <div class="portrait-wrap">
      <img class="portrait" src="/images/legacy/qingniao.PNG" alt="" />
    </div>
  </section>
</BaseLayout>
