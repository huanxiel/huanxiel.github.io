---
import { Icon } from "astro-icon/components";
import LinkCard from "@/components/mdx/LinkCard.astro";
import MainCard from "@/components/MainCard.astro";
import CardGroup from "@/components/temple/CardGroup.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const friends = [
  "https://mylyn.cn",
  "https://Kendal-ming.github.io",
  "http://blog.zerohzzzz.top",
  "https://unclezhou.top",
  "https://herveyb3b4.github.io",
  "https://salt114514.github.io/",
];
---

<BaseLayout title="Links">
  <MainCard
    title="Friend Links"
    description="原博客留下来的友链现在集中放在这里，后面继续补也更清楚。"
    textOverlay="LINKS"
    infoIcon="lucide:link"
  >
    <div class="space-y-6">
      <div class="flex items-center gap-2 text-primary">
        <Icon name="lucide:users" class="w-5 h-5" />
        <p class="text-sm font-medium">A small list carried over from the previous blog.</p>
      </div>

      <CardGroup cols="2">
        {
          friends.map((href) => {
            const hostname = new URL(href).hostname.replace(/^www\./, "");
            return (
              <LinkCard
                title={hostname}
                desc={href}
                url={href}
                icon="lucide:globe"
                categories={["Friend Link"]}
              />
            );
          })
        }
      </CardGroup>
    </div>
  </MainCard>
</BaseLayout>
