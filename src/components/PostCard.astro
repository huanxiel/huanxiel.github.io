---
interface Props {
  href: string;
  title: string;
  description: string;
  date: string;
  cover?: string;
}

const { href, title, description, date, cover } = Astro.props;
---

<a class="post-card" href={href}>
  {cover && <img src={cover} alt="" loading="lazy" />}
  <div class="post-card-copy">
    <p class="eyebrow">{date}</p>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>
