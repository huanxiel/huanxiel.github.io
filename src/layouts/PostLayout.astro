---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  cover?: string;
  tags?: string[];
}

const { title, description, date, updated, cover, tags = [] } = Astro.props;
---

<BaseLayout title={`${title} | LMF`} description={description}>
  <article class="post-shell">
    <header class="post-hero">
      {cover && <img class="post-cover" src={cover} alt="" />}
      <div class="post-copy">
        <p class="eyebrow">Post</p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
        <div class="post-meta">
          <span>{date.toLocaleDateString("zh-CN")}</span>
          {updated && <span>Updated {updated.toLocaleDateString("zh-CN")}</span>}
        </div>
        {tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}
      </div>
    </header>
    <div class="post-body">
      <slot />
    </div>
  </article>
</BaseLayout>
